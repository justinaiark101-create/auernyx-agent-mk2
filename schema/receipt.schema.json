{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mk2.local/schema/receipt.schema.json",
  "title": "Mk2 Alteration Receipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "receiptId",
    "intentId",
    "createdAt",
    "actorId",
    "run",
    "checks",
    "hashes",
    "result"
  ],
  "properties": {
    "receiptId": {
      "type": "string",
      "pattern": "^[0-9]{13}-[a-f0-9]{12}$"
    },
    "intentId": {
      "type": "string"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "actorId": {
      "type": "string"
    },
    "run": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "runId",
        "runner",
        "os",
        "cwd",
        "command"
      ],
      "properties": {
        "runId": {
          "type": "string"
        },
        "runner": {
          "type": "string"
        },
        "os": {
          "type": "string"
        },
        "cwd": {
          "type": "string"
        },
        "command": {
          "type": "string"
        },
        "envSummary": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "status"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "pass",
              "fail",
              "skip"
            ]
          },
          "detail": {
            "type": "string"
          }
        }
      }
    },
    "hashes": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "algorithm",
        "manifest"
      ],
      "properties": {
        "algorithm": {
          "type": "string",
          "enum": [
            "sha256"
          ]
        },
        "manifest": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "path",
              "sha256"
            ],
            "properties": {
              "path": {
                "type": "string"
              },
              "sha256": {
                "type": "string",
                "pattern": "^[A-Fa-f0-9]{64}$"
              }
            }
          }
        }
      }
    },
    "result": {
      "type": "string",
      "enum": [
        "pass",
        "fail"
      ]
    },
    "notes": {
      "type": "string"
    }
  }
}