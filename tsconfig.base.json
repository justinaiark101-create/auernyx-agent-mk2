{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020"],

    "rootDir": "./",
    "strict": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "declaration": true,

    "moduleResolution": "Bundler"
  },
  "include": ["index.ts", "core/**/*", "capabilities/**/*", "clients/**/*"],
  "exclude": ["node_modules", "dist", "logs", "artifacts", "**/*.test.ts"]
}
